# Backend Environment Variables
# Copy this to .env and fill in your values

# Neon PostgreSQL (includes sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET="your-32-byte-hex-secret-here"
JWT_REFRESH_SECRET="your-32-byte-hex-secret-here"

# Optional: App timezone (IANA format)
APP_TZ="UTC"

# Optional: Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# Optional: Node environment
NODE_ENV="development"

# Optional: Server port
PORT=3001