{
  "name": "healthcare-backend",
  "version": "1.0.0",
  "description": "Healthcare Appointment & Follow-up Manager Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "test": "jest --config tests/jest.config.cjs",
    "test:race": "jest --config tests/jest.config.cjs tests/race",
    "test:llm": "jest --config tests/jest.config.cjs tests/llm",
    "test:email": "jest --config tests/jest.config.cjs tests/email",
    "test:calendar": "jest --config tests/jest.config.cjs tests/calendar",
    "test:leave": "jest --config tests/jest.config.cjs tests/leave",
    "test:rbac": "jest --config tests/jest.config.cjs tests/rbac",
    "test:mixed": "jest --config tests/jest.config.cjs tests/mixed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "argon2": "^0.31.2",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.46.0",
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
