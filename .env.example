# =============================================================
# .env.example — Healthcare Appointment & Follow-up Manager
# Copy this file to .env and fill in real values before running.
# Never commit .env — only .env.example is safe to commit.
# =============================================================

# ── Database (Neon free tier — neon.tech) ─────────────────────
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Redis (Upstash free tier — upstash.com) ───────────────────
# Must use rediss:// (TLS) — NOT the REST URL. Required for BullMQ.
UPSTASH_REDIS_TLS_URL=rediss://default:your_token@your-hostname.upstash.io:6379

# ── Auth ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OAUTH_TOKEN_ENC_KEY=replace_with_32_byte_base64_string

# ── Email (Resend — resend.com, free tier: 3000/mo, 100/day) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For testing without a domain, use: onboarding@resend.dev
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_DAILY_CAP=100

# ── Google Calendar (Google Cloud Console — console.cloud.google.com) ──
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# Must match the redirect URI registered in Google Cloud Console exactly
GOOGLE_OAUTH_REDIRECT_URI=https://your-backend.onrender.com/api/calendar/callback
CALENDAR_WORKER_CONCURRENCY=2

# ── LLM (NVIDIA NIM — build.nvidia.com, free tier: ~40 req/min) ──
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_NIM_MODEL=z-ai/glm-5.2
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_TIMEOUT_MS=30000

# ── App ───────────────────────────────────────────────────────
PORT=3001
APP_TZ=Asia/Kolkata
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_OAUTH_RETURN_URL=https://your-frontend.vercel.app/settings/calendar
BOOKING_HOLD_TTL_SECONDS=300
BOOKING_CANCEL_CUTOFF_HOURS=6
FOLLOW_UP_MAX_PER_BOOKING=5

# ── Frontend (add NEXT_PUBLIC_ prefix for client-side vars) ───
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com