// backend/prisma/schema.prisma
// Healthcare Appointment & Follow-up Manager — Database Schema (Module 1)
// Neon PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum Severity {
  MILD
  MODERATE
  SEVERE
}

enum Frequency {
  ONCE_DAILY
  TWICE_DAILY
  THRICE_DAILY
  QID
  WEEKLY
  PRN
  CUSTOM
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  BOOKING_CANCELLATION
  BOOKING_RESCHEDULE
  MEDICATION_REMINDER
  LEAVE_NOTICE
}

enum NotificationStatus {
  QUEUED
  SENDING
  SENT
  RETRYING
  FAILED
  DEAD
}

enum LlmStatus {
  PENDING
  GENERATED
  RETRYING
  FALLBACK
  FAILED
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum SyncStatus {
  PENDING
  SYNCED
  RETRYING
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS — base auth table
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String    @map("password_hash")
  role             Role
  isActive         Boolean   @default(true) @map("is_active")
  emailVerifiedAt  DateTime? @map("email_verified_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  doctorProfile    DoctorProfile?
  patientProfile   PatientProfile?
  oauthToken       OauthToken?
  refreshTokens    RefreshToken[]
  prescriptionsAsDoctor Prescription[] @relation("DoctorPrescriptions")
  prescriptionsAsPatient  Prescription[] @relation("PatientPrescriptions")
  notifications    Notification[]

  @@map("users")
  @@index([role, isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// DOCTOR_PROFILES
// ─────────────────────────────────────────────────────────────────────────────

model DoctorProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique @map("user_id")
  fullName              String   @map("full_name")
  specialisation        String
  workingHours          Json     @map("working_hours") // {mon:{start:"09:00",end:"17:00"}, ...}
  slotDurationMinutes   Int      @default(30) @map("slot_duration_minutes")
  phone                 String?
  calendarResetToken    String?  @map("calendar_reset_token")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveDays   LeaveDay[]    @map("leave_days")
  bookings    Booking[]     @relation("DoctorBookings")
  prescriptions Prescription[] @relation("DoctorPrescriptions")

  @@map("doctor_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAVE_DAYS — separate table for Rule 3 transactional conflict detection
// ─────────────────────────────────────────────────────────────────────────────

model LeaveDay {
  id          String   @id @default(uuid())
  doctorId    String   @map("doctor_id")
  leaveDate   DateTime @map("leave_date")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relation
  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, leaveDate])
  @@map("leave_days")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT_PROFILES
// ─────────────────────────────────────────────────────────────────────────────

model PatientProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  fullName        String   @map("full_name")
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          Gender?
  phone           String?
  address         String?
  bloodGroup      String?  @map("blood_group")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings   Booking[]     @relation("PatientBookings")
  prescriptions Prescription[] @relation("PatientPrescriptions")
  medicationReminders MedicationReminder[]

  @@map("patient_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKINGS — Rule 2: UNIQUE constraint on (doctor_id, booking_date, start_time)
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id           String         @id @default(uuid())
  patientId    String         @map("patient_id")
  doctorId     String         @map("doctor_id")
  bookingDate  DateTime        @map("booking_date")
  startTime    DateTime        @map("start_time")
  status       BookingStatus  @default(CONFIRMED)
  bookedAt     DateTime        @default(now()) @map("booked_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  // Relations
  patient              PatientProfile        @relation("PatientBookings", fields: [patientId], references: [id], onDelete: Cascade)
  doctor               DoctorProfile         @relation("DoctorBookings", fields: [doctorId], references: [id], onDelete: Cascade)
  symptomForm          SymptomForm?
  preVisitSummary      PreVisitSummary?
  postVisitSummary     PostVisitSummary?
  calendarEvent        CalendarEvent?
  prescriptions        Prescription[]
  notifications        Notification[]

  // Rule 2: Partial unique index — cancelled/completed rows don't block slot reuse
  @@unique([doctorId, bookingDate, startTime], name: "unique_doctor_slot_active")
  @@index([patientId, bookingDate])
  @@index([doctorId, bookingDate])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// SYMPTOM_FORMS — Rule 4: filled before booking confirmation
// ─────────────────────────────────────────────────────────────────────────────

model SymptomForm {
  id                  String     @id @default(uuid())
  bookingId           String     @unique @map("booking_id")
  patientId           String     @map("patient_id")
  primaryComplaint    String     @map("primary_complaint")
  durationDays        Int?       @map("duration_days")
  severity            Severity?
  description         String?
  currentMedications  String[]   @default([]) @map("current_medications")
  allergies           String[]   @default([])
  submittedAt         DateTime   @default(now()) @map("submitted_at")

  // Relations
  booking  Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  patient  PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("symptom_forms")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRE_VISIT_SUMMARIES — LLM-generated, best-effort (Rule 4/5)
// ─────────────────────────────────────────────────────────────────────────────

model PreVisitSummary {
  id              String    @id @default(uuid())
  bookingId       String    @unique @map("booking_id")
  symptomFormId   String    @map("symptom_form_id")
  summaryText     String    @map("summary_text")
  llmStatus       LlmStatus @default(PENDING) @map("llm_status")
  llmRequestId    String?   @map("llm_request_id")
  retryCount      Int       @default(0) @map("retry_count")
  generatedAt     DateTime? @map("generated_at")

  // Relations
  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  symptomForm  SymptomForm   @relation(fields: [symptomFormId], references: [id], onDelete: Cascade)

  @@map("pre_visit_summaries")
}

// ─────────────────────────────────────────────────────────────────────────────
// POST_VISIT_SUMMARIES — LLM-generated after visit
// ─────────────────────────────────────────────────────────────────────────────

model PostVisitSummary {
  id              String    @id @default(uuid())
  bookingId       String    @unique @map("booking_id")
  doctorNotes     String?   @map("doctor_notes")
  summaryText     String    @map("summary_text")
  llmStatus       LlmStatus @default(PENDING) @map("llm_status")
  llmRequestId    String?   @map("llm_request_id")
  retryCount      Int       @default(0) @map("retry_count")
  generatedAt     DateTime? @map("generated_at")

  // Relations
  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("post_visit_summaries")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRESCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Prescription {
  id                String     @id @default(uuid())
  bookingId         String     @map("booking_id")
  patientId         String     @map("patient_id")
  doctorId          String     @map("doctor_id")
  medicationName    String     @map("medication_name")
  dosage            String
  frequency         Frequency
  frequencyCustom   String?    @map("frequency_custom")
  startDate         DateTime   @map("start_date")
  endDate           DateTime?  @map("end_date")
  instructions      String?
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  // Relations
  booking           Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  patient           PatientProfile       @relation("PatientPrescriptions", fields: [patientId], references: [id])
  doctor            DoctorProfile        @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  medicationReminders MedicationReminder[]

  @@map("prescriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEDICATION_REMINDERS — Rule 7: populated by background job
// ─────────────────────────────────────────────────────────────────────────────

model MedicationReminder {
  id            String          @id @default(uuid())
  prescriptionId String         @map("prescription_id")
  patientId     String          @map("patient_id")
  remindAt      DateTime        @map("remind_at")
  status        ReminderStatus  @default(PENDING)
  jobId         String?         @map("job_id")
  sentAt        DateTime?       @map("sent_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  // Relations
  prescription Prescription    @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  patient      PatientProfile  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([status, remindAt])
  @@map("medication_reminders")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS — Rule 6: durable email queue state
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id                String           @id @default(uuid())
  notificationType  NotificationType @map("notification_type")
  recipientUserId   String           @map("recipient_user_id")
  recipientRole     Role             @map("recipient_role")
  bookingId         String?          @map("booking_id")
  subject           String
  body              String
  status            NotificationStatus @default(QUEUED)
  bullmqJobId       String?          @map("bullmq_job_id")
  attemptCount      Int              @default(0) @map("attempt_count")
  lastError         String?          @map("last_error")
  scheduledFor      DateTime         @default(now()) @map("scheduled_for")
  sentAt            DateTime?        @map("sent_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  // Relations
  recipientUser User   @relation(fields: [recipientUserId], references: [id])
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([status, scheduledFor])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// CALENDAR_EVENTS — Rule 8: Google Calendar linkage
// ─────────────────────────────────────────────────────────────────────────────

model CalendarEvent {
  id                      String       @id @default(uuid())
  bookingId               String       @unique @map("booking_id")
  patientEventId          String?      @map("patient_event_id")
  doctorEventId           String?      @map("doctor_event_id")
  patientCalendarConnected Boolean     @default(false) @map("patient_calendar_connected")
  doctorCalendarConnected  Boolean     @default(false) @map("doctor_calendar_connected")
  syncStatus              SyncStatus   @default(PENDING) @map("sync_status")
  lastSyncError           String?      @map("last_sync_error")
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")

  // Relation
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// OAUTH_TOKENS — Google OAuth credentials per user (encrypted at rest)
// ─────────────────────────────────────────────────────────────────────────────

model OauthToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token") // encrypted at rest
  refreshToken String   @map("refresh_token") // encrypted at rest
  scope        String
  tokenType    String   @default("Bearer") @map("token_type")
  expiryDate   DateTime @map("expiry_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relation
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("oauth_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// REFRESH_TOKENS — JWT refresh strategy (hashed storage)
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  tokenHash     String   @unique @map("token_hash") // SHA-256 hash, never plaintext
  expiresAt     DateTime @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  replacedById  String?  @map("replaced_by_id")
  userAgent     String?  @map("user_agent")
  ip            String?
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken? @relation("RefreshTokenChain", fields: [replacedById], references: [id])
  replacedTokens RefreshToken[] @relation("RefreshTokenChain")

  @@index([userId, revokedAt])
  @@map("refresh_tokens")
}